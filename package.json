{
  "name": "dexcalidraw",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm dlx turbo build --filter=@dexcalidraw/database && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start:frontend": "cd ./apps/web && pnpm run start",
    "start:http": "cd ./apps/http-backend && pnpm run start",
    "start:ws": "cd ./apps/ws-backend && pnpm run start",
    "db:seed": "pnpm --filter @dexcalidraw/database exec prisma db seed",
    "db:migrate": "pnpm --filter @dexcalidraw/database exec prisma migrate dev",
    "db:generate": "pnpm --filter @dexcalidraw/database exec prisma generate",
    "db:studio": "pnpm --filter @dexcalidraw/database exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@netlify/plugin-nextjs": "^5.10.0"
  }
}
